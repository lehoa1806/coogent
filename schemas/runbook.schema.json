{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "runbook.schema.json",
    "title": "Coogent Task Runbook",
    "description": "The persistent state file for the Coogent execution engine.",
    "type": "object",
    "required": [
        "project_id",
        "status",
        "current_phase",
        "phases"
    ],
    "additionalProperties": false,
    "properties": {
        "project_id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique identifier for the execution run."
        },
        "status": {
            "type": "string",
            "enum": [
                "idle",
                "running",
                "paused_error",
                "completed"
            ],
            "description": "Global execution status."
        },
        "current_phase": {
            "type": "integer",
            "minimum": 0,
            "description": "Index of the currently executing (or next-to-execute) phase."
        },
        "summary": {
            "type": "string",
            "description": "High-level summary of the entire task (generated by the planner)."
        },
        "implementation_plan": {
            "type": "string",
            "description": "Detailed markdown plan describing the approach, architecture decisions, and key changes."
        },
        "phases": {
            "type": "array",
            "minItems": 1,
            "description": "Ordered collection of micro-tasks.",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "status",
                    "prompt",
                    "context_files",
                    "success_criteria"
                ],
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "integer",
                        "description": "Sequential phase identifier."
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "running",
                            "completed",
                            "failed"
                        ],
                        "description": "Phase execution status."
                    },
                    "prompt": {
                        "type": "string",
                        "minLength": 1,
                        "description": "The explicit instruction to inject into the ephemeral worker agent."
                    },
                    "context_files": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "minLength": 1
                        },
                        "description": "File paths (relative to workspace root) to read and inject."
                    },
                    "success_criteria": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Condition to mark this phase as successful (e.g., 'exit_code:0')."
                    },
                    "depends_on": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        },
                        "description": "Phase IDs that must complete before this phase begins (DAG mode)."
                    },
                    "evaluator": {
                        "type": "string",
                        "enum": [
                            "exit_code",
                            "regex",
                            "toolchain",
                            "test_suite"
                        ],
                        "description": "Evaluator type for success_criteria (default: exit_code)."
                    },
                    "max_retries": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Maximum self-healing retry attempts for this phase."
                    },
                    "context_summary": {
                        "type": "string",
                        "description": "Summarized context of the current phase so downstream agents know what has been done and what should happen next."
                    },
                    "mcpPhaseId": {
                        "type": "string",
                        "description": "The real MCP-server phase ID string (phase-NNN-<uuid>). Set by the Engine at dispatch time and persisted back into the runbook."
                    }
                }
            }
        }
    }
}