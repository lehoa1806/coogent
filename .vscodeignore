# ── Source & Build Tooling (bundled via esbuild) ──────────────────────────────
src/**
tsconfig.json
esbuild.js
jest.config.js

# ── Svelte webview source (bundled into webview-ui/dist/) ──────────────
# NOTE: webview-ui/dist/** is NOT listed — it must be in the VSIX.
webview-ui/node_modules/**
webview-ui/src/**
webview-ui/.svelte-kit/**
webview-ui/tsconfig.json
webview-ui/vite.config.ts
webview-ui/svelte.config.js
webview-ui/package.json
webview-ui/package-lock.json

# ── Dependencies (already bundled) ────────────────────────────────────────────
node_modules/**
package-lock.json

# ── WASM binaries (required at runtime) ───────────────────────────────────────
!out/sql-wasm.wasm

# ── Documentation & Metadata (not needed at runtime) ─────────────────────────
docs/**
CONTRIBUTING.md
.git/**
.gitignore

# ── Development artifacts ─────────────────────────────────────────────────────
.vscode/**
.coogent/**
.DS_Store
*.vsix

# ── Source maps (strip from production builds) ────────────────────────────────
**/*.map

# ── Test files ────────────────────────────────────────────────────────────────
**/__tests__/**
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js

# ── Build artifacts ────────────────────────────────────────────────────────
**/*.d.ts
**/*.tsbuildinfo
