{
  "name": "coogent",
  "displayName": "Coogent — Multi-Agent Engine",
  "description": "Context Diffusion engine for Antigravity IDE. Breaks massive implementation plans into isolated, zero-context micro-tasks executed by ephemeral AI agents.",
  "version": "0.2.0",
  "publisher": "antigravity",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": ">=1.85.0"
  },
  "categories": [
    "Other"
  ],
  "capabilities": {
    "languageModelAccess": true
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "coogent.openMissionControl",
        "title": "Coogent: Open Mission Control",
        "category": "Coogent",
        "icon": "$(rocket)"
      },
      {
        "command": "coogent.newSession",
        "title": "Coogent: New Orchestration Session",
        "category": "Coogent",
        "icon": "$(add)"
      },
      {
        "command": "coogent.loadRunbook",
        "title": "Coogent: Load Runbook",
        "category": "Coogent"
      },
      {
        "command": "coogent.start",
        "title": "Coogent: Start Execution",
        "category": "Coogent"
      },
      {
        "command": "coogent.pause",
        "title": "Coogent: Pause Execution",
        "category": "Coogent"
      },
      {
        "command": "coogent.reset",
        "title": "Coogent: Reset Session",
        "category": "Coogent"
      },
      {
        "command": "coogent.preFlightCheck",
        "title": "Coogent: Pre-Flight Git Check",
        "category": "Coogent"
      },
      {
        "command": "coogent.createSandbox",
        "title": "Coogent: Create Git Sandbox Branch",
        "category": "Coogent"
      },
      {
        "command": "coogent.openDiffReview",
        "title": "Coogent: Open Diff Review",
        "category": "Coogent"
      },
      {
        "command": "coogent.loadSession",
        "title": "Coogent: Load Session",
        "category": "Coogent"
      },
      {
        "command": "coogent.deleteSession",
        "title": "Delete Session",
        "category": "Coogent",
        "icon": "$(trash)"
      },
      {
        "command": "coogent.searchHistory",
        "title": "Search Sessions",
        "category": "Coogent",
        "icon": "$(search)"
      },
      {
        "command": "coogent.refreshHistory",
        "title": "Refresh Sessions",
        "category": "Coogent",
        "icon": "$(refresh)"
      },
      {
        "command": "coogent.dumpState",
        "title": "Coogent: Dump State",
        "category": "Coogent"
      },
      {
        "command": "coogent.resumePending",
        "title": "Coogent: Resume Pending Phases",
        "category": "Coogent"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "coogent.openMissionControl",
          "when": "view == coogent.sidebarMenu",
          "group": "navigation"
        },
        {
          "command": "coogent.newSession",
          "when": "view == coogent.sidebarMenu",
          "group": "navigation"
        },
        {
          "command": "coogent.searchHistory",
          "when": "view == coogent.sidebarMenu",
          "group": "navigation"
        },
        {
          "command": "coogent.refreshHistory",
          "when": "view == coogent.sidebarMenu",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "coogent.deleteSession",
          "when": "view == coogent.sidebarMenu && viewItem == session",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "coogent-sidebar",
          "title": "Coogent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "coogent-sidebar": [
        {
          "id": "coogent.sidebarMenu",
          "name": "Mission Control"
        }
      ]
    },
    "configuration": {
      "title": "Coogent",
      "properties": {
        "coogent.tokenLimit": {
          "type": "number",
          "default": 100000,
          "description": "Maximum token count for context injection per phase."
        },
        "coogent.workerTimeoutMs": {
          "type": "number",
          "default": 900000,
          "description": "Timeout in milliseconds before force-killing a worker agent (default: 15 minutes)."
        },
        "coogent.maxRetries": {
          "type": "number",
          "default": 3,
          "description": "Maximum automatic retries for a failed phase."
        },
        "coogent.logDirectory": {
          "type": "string",
          "default": ".coogent/logs",
          "description": "Directory for session logs (relative to workspace root)."
        },
        "coogent.logLevel": {
          "type": "string",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error",
            "off"
          ],
          "default": "info",
          "description": "Minimum log level written to coogent.log. Messages below this level are suppressed.",
          "enumDescriptions": [
            "All messages (most verbose)",
            "Debug and above",
            "Info and above (default)",
            "Warnings and errors only",
            "Errors only",
            "Disable file logging entirely"
          ]
        },
        "coogent.logMaxSizeMB": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum log file size in MB before rotation."
        },
        "coogent.logMaxBackups": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 10,
          "description": "Number of rotated backup log files to keep."
        },
        "coogent.requirePluginApproval": {
          "type": "boolean",
          "default": true,
          "description": "Require user approval before activating MCP plugins. Disable to auto-load all plugins."
        },
        "coogent.blockOnSecretsDetection": {
          "type": "boolean",
          "default": true,
          "description": "Block phase execution when secrets are detected in context files (default: warn-only)."
        },
        "coogent.blockOnPromptInjection": {
          "type": "boolean",
          "default": true,
          "description": "Block phase execution when prompt injection patterns are detected in phase prompts (default: warn-only)."
        },
        "coogent.enableEncryption": {
          "type": "boolean",
          "default": true,
          "description": "Encrypt .task-runbook.json files at rest using a key stored in VS Code SecretStorage."
        },
        "coogent.maxWorkerOutputBytes": {
          "type": "number",
          "default": 10485760,
          "minimum": 1048576,
          "description": "Maximum stdout/stderr output size per worker in bytes (default: 10 MB)."
        },
        "coogent.maxConcurrentWorkers": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 16,
          "description": "Maximum number of concurrent worker agents."
        },
        "coogent.conversationMode": {
          "type": "string",
          "enum": [
            "isolated",
            "continuous",
            "smart-switch"
          ],
          "default": "isolated",
          "description": "Worker conversation mode: isolated (new conversation per phase), continuous (reuse), or smart-switch (auto-detect)."
        },
        "coogent.smartSwitchTokenThreshold": {
          "type": "number",
          "default": 60000,
          "description": "Token count threshold for smart-switch mode to start a new conversation."
        },
        "coogent.customWorkers": {
          "type": "array",
          "default": [],
          "description": "Custom worker profiles for skill-based routing. These override built-in defaults by ID.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "description",
              "system_prompt",
              "tags"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "system_prompt": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "allowed_tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "coogent.enableShadowMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable shadow mode: run the agent selection pipeline for observability without affecting dispatch."
        },
        "coogent.contextBudgetTokens": {
          "type": "number",
          "default": 150000,
          "minimum": 100000,
          "maximum": 2000000,
          "description": "Maximum token budget for context pack assembly per phase (default: 150,000)."
        },
        "coogent.enableSampling": {
          "type": "boolean",
          "default": false,
          "description": "Enable MCP Sampling for optional AI-assisted workflows (feature flag)."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.coogent/workers.json",
        "url": "./schemas/worker.schema.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lehoa1806/coogent"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings=30"
    ]
  },
  "scripts": {
    "clean": "rimraf out",
    "prepare": "husky",
    "compile": "node esbuild.js",
    "watch": "npm run compile -- --watch",
    "build:webview": "cd webview-ui && npm run build",
    "dev:webview": "cd webview-ui && npm run dev",
    "build": "npm run compile && npm run build:webview",
    "mcp:start": "node out/stdio-server.js",
    "lint": "tsc --noEmit && eslint src/ --max-warnings=30",
    "pretest": "npm run lint",
    "prepackage": "npm run compile -- --minify && npm run build:webview",
    "package": "npx -y @vscode/vsce package",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:webview": "cd webview-ui && npx vitest run",
    "ci": "npm run lint && npm test && npm run test:webview && npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.2",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "js-tiktoken": "^1.0.21",
    "marked": "^17.0.4",
    "mermaid": "^11.12.3",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  }
}